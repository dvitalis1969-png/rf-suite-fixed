{
  "entities": {
    "Presence": {
      "title": "Presence",
      "description": "Tracks user online status in a project",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The user's ID" },
        "userName": { "type": "string", "description": "The user's display name" },
        "lastSeen": { "type": "number", "description": "Timestamp of last activity" },
        "projectId": { "type": "string", "description": "The project ID" }
      },
      "required": ["userId", "userName", "lastSeen", "projectId"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message in a project",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The sender's ID" },
        "userName": { "type": "string", "description": "The sender's name" },
        "text": { "type": "string", "description": "The message text" },
        "timestamp": { "type": "number", "description": "Message timestamp" },
        "projectId": { "type": "string", "description": "The project ID" }
      },
      "required": ["userId", "userName", "text", "timestamp", "projectId"]
    },
    "Plot": {
      "title": "Plot",
      "description": "Shared spectrum plot",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The creator's ID" },
        "userName": { "type": "string", "description": "The creator's name" },
        "timestamp": { "type": "number", "description": "Plot creation timestamp" },
        "projectId": { "type": "string", "description": "The project ID" },
        "imageData": { "type": "string", "description": "Base64 encoded plot image" },
        "description": { "type": "string", "description": "Description of the plot" }
      },
      "required": ["userId", "userName", "timestamp", "projectId", "imageData"]
    }
  },
  "firestore": {
    "/presence/{projectId}/users/{userId}": {
      "schema": { "$ref": "Presence" },
      "description": "User presence in a project"
    },
    "/messages/{projectId}/chat/{messageId}": {
      "schema": { "$ref": "Message" },
      "description": "Chat messages for a project"
    },
    "/plots/{plotId}": {
      "schema": { "$ref": "Plot" },
      "description": "Shared plots"
    }
  }
}
